# ============================================
# Ever Works - Environment Variables
# Multi-tenant Configuration
# ============================================
# Copy this file to .env.local and update with your values
# ============================================

# ============================================
# Application Configuration
# ============================================

# Application Name (used as fallback for site name)
# Default: "Ever Works"
APP_NAME=Ever Works
NEXT_PUBLIC_APP_NAME=Ever Works

# Web Application URL
# Default: "http://localhost:3000"
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# API URL (backend)
# Default: "http://localhost:3100"
# Note: /api will be automatically appended if not present
API_URL=http://localhost:3100

# ============================================
# Site Configuration (Multi-tenant)
# ============================================

# Site Name
# Default: Uses APP_NAME
NEXT_PUBLIC_SITE_NAME=Ever Works

# Site Title (for SEO and metadata)
# Default: Uses APP_NAME
NEXT_PUBLIC_SITE_TITLE=Ever Works

# Site Description (for SEO and metadata)
# Default: "Build Directories with AI"
NEXT_PUBLIC_SITE_DESCRIPTION=Build Directories with AI

# Site Keywords (comma-separated)
# Default: "Ever Works,Directories,AI,Automation,Productivity,Workflow"
NEXT_PUBLIC_SITE_KEYWORDS=Ever Works,Directories,AI,Automation,Productivity,Workflow

# Site Author
# Default: Uses APP_NAME
NEXT_PUBLIC_SITE_AUTHOR=Ever Works

# Site Image (Open Graph image)
# Default: "/logo-light.png"
NEXT_PUBLIC_SITE_IMAGE=/logo-light.png

# ============================================
# Logo & Favicon Configuration
# ============================================

# Logo - Light Mode
# Default: "/logo-light.png"
NEXT_PUBLIC_LOGO_LIGHT=/logo-light.png

# Logo - Dark Mode
# Default: "/logo-ever-work.png"
NEXT_PUBLIC_LOGO_DARK=/logo-ever-work.png

# Favicon - Light Mode
# Default: "/favicon-light.png"
NEXT_PUBLIC_FAVICON_LIGHT=/favicon-light.png

# Favicon - Dark Mode
# Default: "/favicon-dark.png"
NEXT_PUBLIC_FAVICON_DARK=/favicon-dark.png

# ============================================
# Twitter / Social Media Configuration
# ============================================

# Twitter Card Type
# Options: "summary" or "summary_large_image"
# Default: "summary_large_image"
NEXT_PUBLIC_TWITTER_CARD=summary_large_image

# Twitter Title
# Default: Uses APP_NAME
NEXT_PUBLIC_TWITTER_TITLE=Ever Works

# Twitter Description
# Default: Uses NEXT_PUBLIC_SITE_DESCRIPTION or "Build Directories with AI"
NEXT_PUBLIC_TWITTER_DESCRIPTION=Build Directories with AI

# ============================================
# Internationalization (i18n)
# ============================================

# Supported Locales (comma-separated)
# Default: "en,ar,de,es,fr,zh"
NEXT_PUBLIC_LOCALES=en,ar,de,es,fr,zh

# Default Locale
# Default: "en"
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ============================================
# Application Settings
# ============================================

# Directory List Limit (pagination)
# Default: 6
NEXT_PUBLIC_DIRECTORY_LIST_LIMIT=6

# Redirect Search Parameter Key
# Default: "redirect_uri"
REDIRECT_SEARCH_PARAM=redirect_uri

# Allowed Redirect URLs (comma-separated)
# Default: "localhost,127.0.0.1"
ALLOWED_REDIRECT_URLS=localhost,127.0.0.1

# ============================================
# Authentication & Security
# ============================================

# Authentication Secret (Cookie Secret)
# Used for encrypting cookies and session data
# Generate a strong random string for production
# Example: openssl rand -base64 32
COOKIE_SECRET=your-secret-key-here
# Alternative variable name
AUTH_SECRET=your-secret-key-here

# ============================================
# PostHog (server-side feature flags + telemetry)
# ============================================

# PostHog project API key. Same key the monitoring package uses.
# Used by the SERVER for feature-flag evaluation (works-<kind> chips,
# onboarding event relay). The same value also belongs in
# NEXT_PUBLIC_POSTHOG_KEY below — `phc_*` keys are the public project
# key and are safe to ship in the browser bundle.
# POSTHOG_API_KEY=phc_your_project_api_key_here

# PostHog host. Defaults to https://app.posthog.com when unset.
POSTHOG_HOST=https://us.i.posthog.com

# Work-kind chips on /new and /works/new are gated by per-kind feature
# flags named `works-<kind>` (e.g. works-website, works-landing-page,
# works-blog, works-directory, works-awesome-repo, works-store,
# works-company).
# Semantics are FAIL-OPEN: a chip is only marked "Soon" when its flag is
# explicitly false. No PostHog config, an unreachable/erroring PostHog, a
# missing flag, or an undefined value all leave the chip ENABLED — so OSS
# forks with no PostHog run with every kind available.

# ============================================
# PostHog (client-side product analytics)
# ============================================

# Same phc_* value as POSTHOG_API_KEY above — phc_* is the PROJECT (public)
# key and is meant to be shipped in the browser bundle. Drives autocapture,
# session replay, and manual $pageview events from the App Router.
# NEXT_PUBLIC_* values are baked into the bundle at BUILD time, so this
# must be set when `pnpm build` runs (not at runtime). If absent, posthog-js
# silently no-ops — fail-open for OSS forks that don't run PostHog.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================
# Build Configuration
# ============================================

# Next.js Build Output
# Options: "standalone" or "export"
# Leave empty for default
# NEXT_BUILD_OUTPUT=standalone

# Build / release identity shown in the footer (Web chip). These NEXT_PUBLIC_*
# values are baked into the bundle at `next build` time and are injected
# automatically by the docker-build-publish-* workflows (--build-arg ->
# Dockerfile ENV). Leave empty locally; the footer falls back to a `dev` build.
#   NEXT_PUBLIC_BUILD_VERSION  - semver (defaults to the build's package.json version)
#   NEXT_PUBLIC_BUILD_SHA      - full commit SHA the bundle was built from
#   NEXT_PUBLIC_BUILD_REF      - branch or tag (e.g. develop, v1.2.3)
#   NEXT_PUBLIC_BUILD_RUN      - GitHub Actions run number
#   NEXT_PUBLIC_BUILD_TIME     - ISO-8601 build timestamp
# Optional override for the commit-link base (forks):
#   NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/ever-works/ever-works
NEXT_PUBLIC_BUILD_VERSION=
NEXT_PUBLIC_BUILD_SHA=
NEXT_PUBLIC_BUILD_REF=
NEXT_PUBLIC_BUILD_RUN=
NEXT_PUBLIC_BUILD_TIME=

# ============================================
# Notes
# ============================================
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - Variables without NEXT_PUBLIC_ are server-side only
# - Never commit .env.local to version control
# - Use .env.example as a template for your configuration
# ============================================
