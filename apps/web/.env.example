# AUTH SECRET
AUTH_SECRET=cookie-secret-here

# WEB APP
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# SERVER API URL
API_URL=http://localhost:3100

# ALLOWED REDIRECT HOSTS (comma-separated)
# Useful for authenticating external tools; hosts listed here will be redirected back with a session token. 
ALLOWED_REDIRECT_URLS=localhost,127.0.0.1
