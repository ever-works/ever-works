<mjml>
    <mj-head>
        <mj-title>New login to your Ever Works account</mj-title>
        <mj-preview>We noticed a login from a new device</mj-preview>
        <mj-attributes>
            <mj-all
                font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif"
            />
            <mj-text font-size='16px' color='#475569' line-height='1.6' />
            <mj-section background-color='#ffffff' padding='0' />
        </mj-attributes>
    </mj-head>

    <mj-body background-color='#f8fafc'>
        <!-- Logo Section -->
        <mj-section padding='40px 20px 30px'>
            <mj-column>
                <mj-text
                    align='center'
                    font-size='28px'
                    font-weight='600'
                    color='#1e293b'
                    padding='0'
                >
                    Ever Works
                </mj-text>
                <mj-text align='center' font-size='14px' color='#94a3b8' padding='5px 0 0'>
                    by Ever Co.
                </mj-text>
            </mj-column>
        </mj-section>

        <!-- Main Card -->
        <mj-section padding='0 20px 40px'>
            <mj-column>
                <mj-wrapper background-color='#ffffff' border-radius='8px' padding='40px 30px'>
                    <!-- Icon -->
                    <mj-text align='center' font-size='40px' padding-bottom='20px'>
                        🔔
                    </mj-text>

                    <!-- Title -->
                    <mj-text
                        font-size='24px'
                        color='#1e293b'
                        font-weight='600'
                        align='center'
                        padding-bottom='10px'
                    >
                        New Device Login
                    </mj-text>

                    <mj-text align='center' color='#64748b' padding-bottom='20px'>
                        {{#if firstName}}{{firstName}}, we{{else}}We{{/if}}
                        noticed a login to your account from a new device.
                    </mj-text>

                    <!-- Login Details -->
                    <mj-wrapper background-color='#f8fafc' border-radius='6px' padding='20px'>
                        <mj-text font-size='14px' color='#64748b' padding='0'>
                            <strong>Time:</strong>
                            {{loginTime}}<br />
                            <strong>Device:</strong>
                            {{device}}<br />
                            <strong>Browser:</strong>
                            {{browser}}<br />
                            <strong>Location:</strong>
                            {{location}}<br />
                            <strong>IP Address:</strong>
                            {{ipAddress}}
                        </mj-text>
                    </mj-wrapper>

                    <!-- Actions -->
                    <mj-text align='center' font-size='16px' color='#1e293b' padding='30px 0 20px'>
                        Was this you?
                    </mj-text>

                    <mj-button
                        background-color='#1e293b'
                        color='#ffffff'
                        font-size='16px'
                        font-weight='500'
                        padding='0 0 15px'
                        inner-padding='12px 48px'
                        border-radius='6px'
                        href='{{verifyUrl}}'
                    >
                        Yes, this was me
                    </mj-button>

                    <mj-button
                        background-color='#ffffff'
                        color='#ef4444'
                        font-size='16px'
                        font-weight='500'
                        border='2px solid #ef4444'
                        padding='0'
                        inner-padding='10px 48px'
                        border-radius='6px'
                        href='{{secureAccountUrl}}'
                    >
                        No, secure my account
                    </mj-button>
                </mj-wrapper>
            </mj-column>
        </mj-section>

        <!-- Footer -->
        <mj-section padding='0 20px 40px'>
            <mj-column>
                <mj-text align='center' font-size='14px' color='#94a3b8'>
                    © 2024 Ever Co. All rights reserved.
                </mj-text>
            </mj-column>
        </mj-section>
    </mj-body>
</mjml>