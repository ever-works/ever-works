<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to {{appName}}!</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background-color: #f8fafc;
            line-height: 1.6;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
        }
        .logo-section {
            padding: 40px 20px 30px;
            text-align: center;
        }
        .logo-title {
            font-size: 28px;
            font-weight: 600;
            color: #1e293b;
            margin: 0;
        }
        .logo-subtitle {
            font-size: 14px;
            color: #94a3b8;
            margin: 5px 0 0;
        }
        .main-card {
            margin: 0 20px 40px;
            background-color: #ffffff;
            border-radius: 8px;
            padding: 40px 30px;
        }
        .icon {
            text-align: center;
            font-size: 40px;
            margin-bottom: 20px;
        }
        .title {
            font-size: 24px;
            color: #1e293b;
            font-weight: 600;
            text-align: center;
            margin: 0 0 10px;
        }
        .subtitle {
            text-align: center;
            color: #64748b;
            margin: 0 0 30px;
            font-size: 16px;
        }
        .steps-title {
            font-size: 18px;
            color: #1e293b;
            font-weight: 600;
            margin: 0 0 15px;
        }
        .step-box {
            background-color: #f8fafc;
            border-radius: 6px;
            padding: 20px;
            margin-bottom: 15px;
        }
        .step-box.last {
            margin-bottom: 30px;
        }
        .step-title {
            font-size: 16px;
            color: #1e293b;
            font-weight: bold;
            margin: 0 0 8px;
        }
        .step-description {
            font-size: 14px;
            color: #64748b;
            margin: 0;
        }
        .button {
            display: inline-block;
            text-decoration: none;
            background-color: #1e293b;
            color: #ffffff;
            font-size: 16px;
            font-weight: 500;
            padding: 12px 48px;
            border-radius: 6px;
            text-align: center;
            width: 100%;
            box-sizing: border-box;
        }
        .button-container {
            text-align: center;
        }
        .footer {
            padding: 0 20px 40px;
            text-align: center;
        }
        .footer-text {
            font-size: 14px;
            color: #94a3b8;
            margin: 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Logo Section -->
        <div class="logo-section">
            <h1 class="logo-title">{{appName}}</h1>
            <p class="logo-subtitle">by {{companyOwner}}</p>
        </div>

        <!-- Main Card -->
        <div class="main-card">
            <!-- Icon -->
            <div class="icon">🎉</div>

            <!-- Title -->
            <h2 class="title">
                You're all set{{#if firstName}}, {{firstName}}{{/if}}!
            </h2>

            <p class="subtitle">
                Your account is ready. Start building AI-powered directories in minutes.
            </p>

            <!-- Getting Started Steps -->
            <h3 class="steps-title">
                Get started in 3 easy steps:
            </h3>

            <div class="step-box">
                <p class="step-title">1. Create your first directory</p>
                <p class="step-description">
                    Define a topic and let AI populate it with items
                </p>
            </div>

            <div class="step-box">
                <p class="step-title">2. Generate with AI</p>
                <p class="step-description">
                    Use the AI generator to automatically create and organize content
                </p>
            </div>

            <div class="step-box last">
                <p class="step-title">3. Deploy your directory</p>
                <p class="step-description">
                    Publish your directory as a live website
                </p>
            </div>

            <!-- CTA Button -->
            <div class="button-container">
                <a href="{{dashboardUrl}}" class="button">
                    Create Your First Directory
                </a>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer">
            <p class="footer-text">
                Need help? Reply to this email or visit our help center.<br><br>
                © {{currentYear}} {{companyOwner}} All rights reserved.
            </p>
        </div>
    </div>
</body>
</html>