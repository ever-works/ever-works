<mjml>
    <mj-head>
        <mj-title>Reset your Ever Works password</mj-title>
        <mj-preview>We received a request to reset your password</mj-preview>
        <mj-attributes>
            <mj-all
                font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif"
            />
            <mj-text font-size='16px' color='#475569' line-height='1.6' />
            <mj-section background-color='#ffffff' padding='0' />
        </mj-attributes>
    </mj-head>

    <mj-body background-color='#f8fafc'>
        <!-- Logo Section -->
        <mj-section padding='40px 20px 30px'>
            <mj-column>
                <mj-text
                    align='center'
                    font-size='28px'
                    font-weight='600'
                    color='#1e293b'
                    padding='0'
                >
                    Ever Works
                </mj-text>
                <mj-text align='center' font-size='14px' color='#94a3b8' padding='5px 0 0'>
                    by Ever Co.
                </mj-text>
            </mj-column>
        </mj-section>

        <!-- Main Card -->
        <mj-section padding='0 20px 40px'>
            <mj-column>
                <mj-wrapper background-color='#ffffff' border-radius='8px' padding='40px 30px'>
                    <!-- Icon -->
                    <mj-text align='center' font-size='40px' padding-bottom='20px'>
                        🔐
                    </mj-text>

                    <!-- Title -->
                    <mj-text
                        font-size='24px'
                        color='#1e293b'
                        font-weight='600'
                        align='center'
                        padding-bottom='10px'
                    >
                        Reset Your Password
                    </mj-text>

                    <mj-text align='center' color='#64748b' padding-bottom='30px'>
                        {{#if firstName}}Hi {{firstName}}, we{{else}}We{{/if}}
                        received a request to reset the password for your Ever Works account. Click
                        the button below to create a new password.
                    </mj-text>

                    <!-- CTA Button -->
                    <mj-button
                        background-color='#1e293b'
                        color='#ffffff'
                        font-size='16px'
                        font-weight='500'
                        padding='25px 0'
                        inner-padding='12px 48px'
                        border-radius='6px'
                        href='{{resetUrl}}'
                    >
                        Reset Password
                    </mj-button>

                    <!-- Security Notice -->
                    <mj-text align='center' font-size='14px' color='#94a3b8' padding-top='30px'>
                        This link expires in
                        {{expiresIn}}
                        for security reasons.
                    </mj-text>

                    <!-- Divider -->
                    <mj-divider
                        border-color='#e2e8f0'
                        border-width='1px'
                        padding='30px 0'
                    ></mj-divider>

                    <!-- Didn't request -->
                    <mj-text align='center' font-size='14px' color='#94a3b8'>
                        Didn't request this? You can safely ignore this email.<br />
                        Your password won't change unless you click the button above.
                    </mj-text>
                </mj-wrapper>
            </mj-column>
        </mj-section>

        <!-- Footer -->
        <mj-section padding='0 20px 40px'>
            <mj-column>
                <mj-text align='center' font-size='14px' color='#94a3b8'>
                    © 2024 Ever Co. All rights reserved.
                </mj-text>
            </mj-column>
        </mj-section>
    </mj-body>
</mjml>