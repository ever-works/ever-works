<mjml>
    <mj-head>
        <mj-title>Your Ever Works password has been changed</mj-title>
        <mj-preview>This is a confirmation that your password was successfully changed</mj-preview>
        <mj-attributes>
            <mj-all
                font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif"
            />
            <mj-text font-size='16px' color='#475569' line-height='1.6' />
            <mj-section background-color='#ffffff' padding='0' />
        </mj-attributes>
    </mj-head>

    <mj-body background-color='#f8fafc'>
        <!-- Logo Section -->
        <mj-section padding='40px 20px 30px'>
            <mj-column>
                <mj-text
                    align='center'
                    font-size='28px'
                    font-weight='600'
                    color='#1e293b'
                    padding='0'
                >
                    Ever Works
                </mj-text>
                <mj-text align='center' font-size='14px' color='#94a3b8' padding='5px 0 0'>
                    by Ever Co.
                </mj-text>
            </mj-column>
        </mj-section>

        <!-- Main Card -->
        <mj-section padding='0 20px 40px'>
            <mj-column>
                <mj-wrapper background-color='#ffffff' border-radius='8px' padding='40px 30px'>
                    <!-- Icon -->
                    <mj-text align='center' font-size='40px' padding-bottom='20px'>
                        ✅
                    </mj-text>

                    <!-- Title -->
                    <mj-text
                        font-size='24px'
                        color='#1e293b'
                        font-weight='600'
                        align='center'
                        padding-bottom='10px'
                    >
                        Password Changed Successfully
                    </mj-text>

                    <mj-text align='center' color='#64748b' padding-bottom='20px'>
                        {{#if firstName}}{{firstName}}, your{{else}}Your{{/if}}
                        Ever Works password has been changed successfully.
                    </mj-text>

                    <!-- Details -->
                    <mj-wrapper background-color='#f8fafc' border-radius='6px' padding='20px'>
                        <mj-text font-size='14px' color='#64748b' padding='0'>
                            <strong>Changed on:</strong>
                            {{changedAt}}<br />
                            <strong>IP Address:</strong>
                            {{ipAddress}}<br />
                            <strong>Location:</strong>
                            {{location}}<br />
                            <strong>Device:</strong>
                            {{device}}{{#if browser}}<br />
                                <strong>Browser:</strong>
                                {{browser}}{{/if}}
                        </mj-text>
                    </mj-wrapper>

                    <!-- Security Alert -->
                    <mj-text align='center' font-size='14px' color='#94a3b8' padding-top='30px'>
                        If you didn't make this change, please secure your account immediately.
                    </mj-text>

                    <!-- CTA Button -->
                    <mj-button
                        background-color='#ef4444'
                        color='#ffffff'
                        font-size='14px'
                        font-weight='500'
                        padding='20px 0 0'
                        inner-padding='10px 24px'
                        border-radius='6px'
                        href='{{secureAccountUrl}}'
                    >
                        Secure My Account
                    </mj-button>
                </mj-wrapper>
            </mj-column>
        </mj-section>

        <!-- Footer -->
        <mj-section padding='0 20px 40px'>
            <mj-column>
                <mj-text align='center' font-size='14px' color='#94a3b8'>
                    © 2024 Ever Co. All rights reserved.
                </mj-text>
            </mj-column>
        </mj-section>
    </mj-body>
</mjml>