{
    "name": "ever-works-api",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "dev": "nest start -b swc --watch",
        "start": "nest start -b swc",
        "start:dev": "nest start -b swc --watch",
        "start:debug": "nest start -b swc --debug --watch",
        "start:prod": "node dist/main",
        "build": "nest build -b swc",
        "format": "prettier --write \"**/*.{ts,tsx,jsx,json,css,md}\"",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "typeorm": "ts-node --project tsconfig.typeorm.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
        "migration:generate": "npm run typeorm -- migration:generate -d typeorm.config.ts",
        "migration:run": "npm run typeorm -- migration:run -d typeorm.config.ts",
        "migration:revert": "npm run typeorm -- migration:revert -d typeorm.config.ts",
        "migration:show": "npm run typeorm -- migration:show -d typeorm.config.ts",
        "schema:log": "npm run typeorm -- schema:log -d typeorm.config.ts"
    },
    "dependencies": {
        "@ever-works/agent": "workspace:*",
        "@ever-works/monitoring": "workspace:*",
        "@ever-works/plugin": "workspace:*",
        "@ever-works/trigger-tasks": "workspace:*",
        "@nestjs-modules/mailer": "^2.0.2",
        "@nestjs/axios": "^4.0.1",
        "@nestjs/common": "^11.1.13",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.1.13",
        "@nestjs/event-emitter": "^3.0.1",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.13",
        "@nestjs/schedule": "^6.1.0",
        "@nestjs/swagger": "^11.2.5",
        "@nestjs/throttler": "^6.5.0",
        "@nestjs/typeorm": "^11.0.0",
        "@scalar/nestjs-api-reference": "^1.0.20",
        "axios": "^1.13.5",
        "bcrypt": "^6.0.0",
        "better-sqlite3": "^12.5.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "handlebars": "^4.7.8",
        "helmet": "^8.1.0",
        "mysql2": "^3.16.0",
        "nodemailer": "^7.0.12",
        "resend": "^6.9.2",
        "passport": "^0.7.0",
        "passport-github2": "^0.1.12",
        "passport-google-oauth20": "^2.0.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.16.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "simstudio-ts-sdk": "^0.1.2",
        "superjson": "^1.13.3",
        "typeorm": "^0.3.28"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.14",
        "@nestjs/schematics": "^11.0.9",
        "@nestjs/testing": "^11.1.13",
        "@swc/cli": "^0.6.0",
        "@swc/core": "^1.15.8",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.6",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.19.3",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/supertest": "^6.0.3",
        "globals": "^16.5.0",
        "jest": "^29.7.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.1.4",
        "ts-jest": "^29.2.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3"
    }
