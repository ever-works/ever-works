# App type
APP_TYPE=api

# API Port
PORT=3100

# Debugging
HTTP_DEBUG=false

# WEB App URL
WEB_URL=http://localhost:3000

# App auth secret
AUTH_SECRET=secret_key_here

# 32-byte hex key for per-Work PLATFORM_SYNC_SECRET / WEBHOOK_SECRET encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLATFORM_ENCRYPTION_KEY=

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# AUTH RUNTIME CONFIGURATION
# =============================================================================

AUTH_URL=http://localhost:3100/api/internal/auth-runtime

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================

# GitHub Auth
GH_CLIENT_ID=
GH_CLIENT_SECRET=
GH_CALLBACK_URL="${WEB_URL}/api/oauth/github/callback"

###############
# Google Auth
###############

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL="${WEB_URL}/api/oauth/google/callback"

# Facebook Auth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL="${WEB_URL}/api/oauth/facebook/callback"

# LinkedIn Auth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL="${WEB_URL}/api/oauth/linkedin/callback"

# Jitsu Analytics
JITSU_HOST=
JITSU_WRITE_KEY=

# =============================================================================
# Trigger.dev configuration
# =============================================================================
TRIGGER_ENABLED=false
TRIGGER_SECRET_KEY=
TRIGGER_API_URL="https://api.trigger.dev"
TRIGGER_INTERNAL_SECRET=
# micro | small-1x | small-2x | medium-1x | medium-2x | large-1x | large-2x
TRIGGER_MACHINE=
# To be defined on Trigger.dev Worker or Trigger.dev Cloud.
TRIGGER_INTERNAL_API_URL=http://localhost:3100/internal/trigger

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database type: sqlite | postgres | mysql
DATABASE_TYPE=sqlite

# =============================================================================
# SQLITE CONFIGURATION (when DATABASE_TYPE=sqlite)
# =============================================================================

# SQLite database path (optional - uses defaults if not set)
# API apps default: :memory: (development) or /tmp/ever-works-api.db (production)
# DATABASE_PATH=/path/to/your/database.db

# Force in-memory database (true/false) - overrides default behavior
# Keep this disabled when auth runtime is enabled because sessions require persistent storage.
DATABASE_IN_MEMORY=false

# =============================================================================
# POSTGRESQL CONFIGURATION (when DATABASE_TYPE=postgres)
# =============================================================================

# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your_password
# DATABASE_NAME=ever_works
# DATABASE_URL=

# =============================================================================
# MYSQL/MARIADB CONFIGURATION (when DATABASE_TYPE=mysql)
# =============================================================================

# DATABASE_HOST=localhost
# DATABASE_PORT=3306
# DATABASE_USERNAME=root
# DATABASE_PASSWORD=your_password
# DATABASE_NAME=ever_works
# DATABASE_URL=

# =============================================================================
# COMMON DATABASE OPTIONS
# =============================================================================

# Enable SQL query logging (true/false)
DATABASE_LOGGING=false

# Enable SSL/TLS for database connections (true/false)
DATABASE_SSL_MODE=false
DATABASE_CA_CERT=

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# MAILER PROVIDER: smtp|none|resend
MAILER_PROVIDER=none

# Email from
EMAIL_FROM='Ever Works <ever@ever.works>'

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_password
SMTP_SECURE=false
SMTP_IGNORE_TLS=false

# RESEND
RESEND_APIKEY=
RESEND_EMAIL_FROM=

# =============================================================================
# TWENTY CONFIGURATION
# =============================================================================

TWENTY_CRM_BASE_URL=https://api.twenty.com
TWENTY_CRM_API_KEY=
TWENTY_CRM_WORKSPACE_ID=

# Per-tenant Twenty workspace credentials (cross-tenant isolation).
# REQUIRED to use the tenant-scoped CRM endpoints (companies/people): each tenant
# must have its OWN Twenty workspace + API key here so a caller can only ever
# touch their own workspace. JSON map of tenantId -> { apiKey, workspaceId,
# apiUrl? }. A tenant with no entry (or an entry without an apiKey) FAILS CLOSED
# — the request is refused (404); we never fall back to the shared key for
# tenant-scoped calls. The shared values above are used only by internal/system
# sync paths (which are not per-caller).
# Example: {"<tenant-uuid>":{"apiKey":"...","workspaceId":"..."}}
TWENTY_CRM_TENANTS=

TWENTY_CRM_MAX_RETRIES=3
TWENTY_CRM_RETRY_DELAY_MS=1000
TWENTY_CRM_BACKOFF_MULTIPLIER=2
TWENTY_CRM_TIMEOUT_MS=30000
TWENTY_CRM_ENABLE_LOGGING=true
TWENTY_CRM_WORKSPACE_ID=

# =============================================================================
# DIRECTORY GENERATION
# =============================================================================

# Stale generation timeout in hours (default: 2 hours)
DIRECTORY_STALE_TIMEOUT_HOURS=2

# =============================================================================
# SCHEDULED DIRECTORY UPDATES
# =============================================================================

SCHEDULED_UPDATES_ENABLED=true
SCHEDULED_UPDATES_DISPATCH_INTERVAL_MINUTES=5
SCHEDULED_UPDATES_MAX_BATCH=25
SCHEDULED_UPDATES_MAX_FAILURE_BEFORE_PAUSE=3
PAY_PER_USE_PRICE_USD=5

# =============================================================================
# SUBSCRIPTIONS & BILLING
# =============================================================================

SUBSCRIPTIONS_ENABLED=false
BILLING_DEFAULT_CURRENCY=usd
SUBSCRIPTIONS_DEFAULT_PLAN=free
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# WEBSITE TEMPLATE AUTO-UPDATE
# =============================================================================

# Enable automatic website template updates (true/false)
WEBSITE_TEMPLATE_AUTO_UPDATE_ENABLED=true

# Beta branch name for beta template updates
WEBSITE_TEMPLATE_BETA_BRANCH=stage


# ============================================
# Sentry (error tracking, traces, profiling)
# ============================================
# Get the DSN from https://sentry.io -> Ever Works project -> Settings ->
# Client Keys. Without DSN set, Sentry SDK is a no-op (graceful).
SENTRY_DSN=
# 'development' / 'staging' / 'production'. Deployed envs override
# via the k8s manifest; local dev defaults to 'development'.
SENTRY_ENVIRONMENT=development
# Override the auto-picked sample rate (default 0.1 in prod, 1.0 elsewhere).
# SENTRY_TRACES_SAMPLE_RATE=1.0

# ============================================
# PostHog (server-side analytics + feature flags + logs)
# ============================================
# Project (public) API key — same phc_* as the marketing site uses;
# not a security secret. Without it set, PostHog SDK is a no-op (graceful).
# When POSTHOG_API_KEY is set, all NestJS Logger emits (log/warn/error/
# debug/verbose) are also forwarded to PostHog Logs as `$log` events.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com


# ============================== PLUGINS ========================================

# GitHub Plugin (separate from GitHub Auth above)
PLUGIN_GITHUB_CLIENT_ID=
PLUGIN_GITHUB_CLIENT_SECRET=
# Redirect URL or callback: [WEB_DOMAIN]/api/oauth/github/callback/plugins

# Tavily Plugin
PLUGIN_TAVILY_API_KEY=

# ScreenshotOne Plugin
PLUGIN_SCREENSHOTONE_ACCESS_KEY=
PLUGIN_SCREENSHOTONE_SECRET_KEY=


# OpenRouter Plugin
PLUGIN_OPENROUTER_API_KEY=
PLUGIN_OPENROUTER_DEFAULT_MODEL='openai/gpt-5-nano'
PLUGIN_OPENROUTER_SIMPLE_MODEL='openai/gpt-5-nano'
PLUGIN_OPENROUTER_MEDIUM_MODEL='moonshotai/kimi-k2.5'
PLUGIN_OPENROUTER_COMPLEX_MODEL='moonshotai/kimi-k2.5'


# ─── Onboarding Wizard v2 — Ever Works default providers ────────────────────
# Each platform-default is env-gated until its external resource is provisioned.

# "Ever Works Git" storage — push customer repos to a platform-owned GitHub org
STORAGE_EVER_WORKS_GIT_ENABLED=false
EVER_WORKS_CUSTOMERS_GITHUB_ORG=ever-works-cloud
EVER_WORKS_CUSTOMERS_GITHUB_PAT=
EVER_WORKS_CUSTOMERS_GITHUB_VISIBILITY=private

# "Ever Works" deploy — platform-owned Kubernetes tenant cluster
DEPLOY_EVER_WORKS_ENABLED=false
EVER_WORKS_DEPLOY_KUBECONFIG=
EVER_WORKS_DEPLOY_KUBECONFIG_PATH=
EVER_WORKS_DEPLOY_NAMESPACE=ever-works-tenants
EVER_WORKS_DEPLOY_INGRESS_HOST_TEMPLATE={slug}.ever.works
EVER_WORKS_DEPLOY_INGRESS_CLASS=nginx
EVER_WORKS_DEPLOY_TLS_ISSUER=letsencrypt-prod
EVER_WORKS_DEPLOY_REGISTRY=
EVER_WORKS_DEPLOY_MAX_WORKS_PER_USER=3

# ─── User Research Agent (EW-584) ───────────────────────────────────────────
# Tool-calling AI agent that researches new users at signup and generates
# personalized Work proposals.

# Kill switch for the signup listener (default on).
USER_RESEARCH_ENABLED=true

# Daily @Cron rerun for users with stale profiles (default off — opt in per env).
USER_RESEARCH_SCHEDULED_RERUN_ENABLED=false

# User-facing research controls. Timeout is milliseconds; runs are per user per day.
USER_RESEARCH_TIMEOUT_MS=1800000
USER_RESEARCH_MAX_RUNS_PER_DAY=3

# =============================================================================
# SECURITY (2026-05-17 audit) — see docs/specs/security/THREAT-MODEL.md
# =============================================================================

# C-08: 32-byte hex key for at-rest AES-256-GCM encryption of plugin secret
# settings (envelope-prefixed `enc::v1::...`). REQUIRED in production —
# the app refuses to start if encrypted secrets exist without this key.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLUGIN_SECRET_ENCRYPTION_KEY=

# C-04: comma-separated allow-list of hosts permitted in user-supplied
# `emailVerificationCallbackUrl` / `passwordResetCallbackUrl`. WEB_URL's host
# is always included by default. Add CLI / admin / docs hosts as needed.
# Example: ALLOWED_CALLBACK_HOSTS=app.example.com,cli.example.com
ALLOWED_CALLBACK_HOSTS=

# H-17: per-user login lockout. Defaults: 5 failed verifies → 15 min lock.
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_DURATION_MS=900000

# M-19: HTTP body parser size limit (Express bytes-style suffix or number).
# Default 1mb. Increase only for endpoints that legitimately accept larger
# uploads — most don't.
BODY_LIMIT=1mb

# C-11: comma-separated GitHub org logins whose verified members are allowed
# to trigger community-PR auto-apply. Default empty = community-PR auto-apply
# disabled entirely. Add only orgs you trust to vet contributors.
# Example: COMMUNITY_PR_VERIFIED_ORGS=ever-works,ever-co
COMMUNITY_PR_VERIFIED_ORGS=

# H-24: audit-log every agent-pipeline bash invocation to structured logs
# (CloudWatch / Loki / Sentry breadcrumbs). 'true' to enable. Recommended
# in production for forensic visibility into prompt-injected agent actions.
AGENT_BASH_AUDIT_LOG=false

# =============================================================================
# BUILD / RELEASE INFO (surfaced at GET /api/version and GET /api/health/ready)
# =============================================================================
# These are injected automatically at GitHub-build time by the
# docker-build-publish-* workflows (--build-arg -> Dockerfile ENV). You do not
# normally set them by hand; leave them empty locally and /api/version falls
# back to the package.json version + a `dev` commit.
#   BUILD_VERSION  - semver (defaults to the build's package.json version)
#   GIT_SHA        - full commit SHA the image was built from
#   GIT_REF        - branch or tag (e.g. develop, v1.2.3)
#   BUILD_RUN      - GitHub Actions run number
#   BUILD_TIME     - ISO-8601 build timestamp
# Optional override for the commit-link base (forks):
#   GITHUB_REPO_URL=https://github.com/ever-works/ever-works
BUILD_VERSION=
GIT_SHA=
GIT_REF=
BUILD_RUN=
BUILD_TIME=
