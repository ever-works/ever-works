{
    "name": "@ever-works/cli",
    "version": "0.1.0",
    "description": "Ever Works Internal CLI",
    "author": {
        "name": "Ever Co. LTD",
        "email": "ever@ever.co",
        "url": "https://ever.co"
    },
    "license": "AGPL-3.0",
    "private": true,
    "scripts": {
        "cli": "cd dist && node dist/cli.js",
        "build": "nest build",
        "type-check": "tsc -p tsconfig.build.json --noEmit",
        "build:cli": "node build.js",
        "publish:cli": "pnpm build:cli && cd dist && pnpm publish",
        "test:cli": "cd dist && pnpm install && node cli.js --help",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@ever-works/agent": "workspace:*",
        "@ever-works/cli-shared": "workspace:*",
        "@ever-works/vercel-plugin": "workspace:*",
        "@nestjs/common": "^11.1.18",
        "@nestjs/core": "^11.1.18",
        "@nestjs/event-emitter": "^3.0.1",
        "better-sqlite3": "^12.5.0",
        "chalk": "^4.1.2",
        "fs-extra": "^11.3.3",
        "inquirer": "^12.11.1",
        "nest-commander": "^3.20.1",
        "ora": "^5.4.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.18",
        "@nestjs/schematics": "^11.0.10",
        "@swc/cli": "^0.8.1",
        "@swc/core": "^1.15.24",
        "@types/fs-extra": "^11.0.4",
        "@types/inquirer": "^9.0.9",
        "@types/node": "^22.19.3",
        "esbuild": "^0.25.12",
        "globals": "^16.5.0",
        "source-map-support": "^0.5.21",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3",
        "vitest": "^3.2.1"
    }
