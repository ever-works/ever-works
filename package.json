{
	"name": "ever-works",
	"version": "0.1.0",
	"description": "Ever Works - Open Work Builder Platform",
	"homepage": "https://ever.works",
	"repository": {
		"type": "git",
		"url": "https://github.com/ever-works/ever-works.git"
	},
	"bugs": {
		"url": "https://github.com/ever-works/ever-works/issues"
	},
	"author": {
		"name": "Ever Co. LTD",
		"email": "ever@ever.co",
		"url": "https://ever.co"
	},
	"private": true,
	"scripts": {
		"dev:apps": "turbo run dev --filter=./apps/* --filter=!./apps/docs",
		"dev:api": "turbo run dev --filter=ever-works-api",
		"dev:web": "turbo run dev --filter=ever-works-web",
		"dev:docs": "turbo run dev --filter=ever-works-docs",
		"dev:trigger": "turbo run dev:trigger --filter=@ever-works/trigger-tasks",
		"deploy:trigger": "turbo run deploy:trigger --filter=@ever-works/trigger-tasks",
		"build": "turbo run build --filter=!./apps/docs",
		"build:all": "turbo run build",
		"build:apps": "turbo run build --filter=./apps/* --filter=!./apps/docs",
		"build:packages": "turbo run build --filter=./packages/*",
		"build:plugins": "turbo run build --filter=./packages/plugin --filter=./packages/plugins/*",
		"build:api": "turbo run build --filter=ever-works-api",
		"build:web": "turbo run build --filter=ever-works-web",
		"build:docs": "turbo run build --filter=ever-works-docs",
		"prepare:husky": "husky install .husky",
		"prepare": "husky",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"type-check": "turbo run type-check",
		"clean": "turbo run clean",
		"format": "prettier --write \"**/*.{ts,tsx,jsx,json,css,md}\" --log-level warn",
		"test:e2e": "turbo run test:e2e --filter=ever-works-web",
		"format:check": "prettier --check \"**/*.{ts,tsx,jsx,json,css,md}\""
	},
	"keywords": [],
	"devDependencies": {
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@types/node": "^22.19.11",
		"husky": "^9.1.7",
		"prettier": "^3.7.4",
		"prettier-eslint-cli": "^8.0.1",
		"prettier-plugin-tailwindcss": "^0.5.14",
		"turbo": "^2.9.14"
	},
	"engines": {
		"node": ">=22",
		"pnpm": ">=9.9.0"
	},
	"packageManager": "pnpm@10.33.3",
	"pnpm": {
		"overrides": {
			"protobufjs@<7.5.5": ">=7.5.5",
			"protobufjs@>=8.0.0 <8.0.1": ">=8.0.1",
			"minimatch@<3.1.4": ">=3.1.4",
			"minimatch@>=4.0.0 <9.0.7": ">=9.0.7",
			"minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
			"picomatch@<2.3.2": ">=2.3.2",
			"picomatch@>=3.0.0 <4.0.4": ">=4.0.4",
			"fast-xml-parser@<5.3.6": ">=5.5.6",
			"fast-xml-parser@>=5.4.0 <5.5.6": ">=5.5.6",
			"flatted@<3.4.2": ">=3.4.2",
			"undici@>=7.0.0 <7.24.0": ">=7.24.0",
			"serialize-javascript@<7.0.3": ">=7.0.3",
			"socket.io-parser@<4.2.6": ">=4.2.6",
			"systeminformation@<5.31.6": ">=5.31.6",
			"defu@<6.1.5": ">=6.1.5",
			"liquidjs@<10.25.7": ">=10.25.7",
			"rollup@>=4.0.0 <4.59.0": ">=4.59.0",
			"@hono/node-server@<1.19.10": ">=1.19.10",
			"hono@<4.12.4": ">=4.12.4",
			"multer@<2.1.1": ">=2.1.1",
			"express-rate-limit@<8.2.2": ">=8.2.2",
			"vite@>=7.0.0 <7.3.2": ">=7.3.2",
			"cookie@<0.7.0": ">=0.7.0",
			"path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
			"lodash@<=4.17.23": ">=4.18.0",
			"fast-uri@<=3.1.1": ">=3.1.2",
			"@babel/plugin-transform-modules-systemjs@>=7.12.0 <=7.29.3": ">=7.29.4",
			"langsmith@<0.6.0": ">=0.6.0",
			"fast-xml-builder@<=1.1.6": ">=1.1.7"
		}
	},
	"prettier": {
		"printWidth": 120,
		"singleQuote": true,
		"semi": true,
		"useTabs": true,
		"tabWidth": 4,
		"arrowParens": "always",
		"trailingComma": "none",
		"quoteProps": "as-needed",
		"overrides": [
			{
				"files": "*.scss",
				"options": {
					"useTabs": false,
					"tabWidth": 2
				}
			},
			{
				"files": "*.yml",
				"options": {
					"useTabs": false,
					"tabWidth": 2
				}
			}
		]
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"snyk": true
}
