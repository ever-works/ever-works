{
	"name": "ever-works",
	"version": "0.1.0",
	"description": "Ever Works - Open Directory Builder Platform",
	"homepage": "https://ever.works",
	"repository": {
		"type": "git",
		"url": "https://github.com/ever-works/ever-works.git"
	},
	"bugs": {
		"url": "https://github.com/ever-works/ever-works/issues"
	},
	"author": {
		"name": "Ever Co. LTD",
		"email": "ever@ever.co",
		"url": "https://ever.co"
	},
	"private": true,
	"scripts": {
		"dev": "turbo dev",
		"dev:api": "turbo dev --filter=ever-works-api",
		"dev:web": "turbo dev --filter=ever-works-web",
		"dev:trigger": "turbo dev:trigger --filter=@packages/tasks",
		"deploy:trigger": "turbo deploy:trigger --filter=@packages/tasks",
		"build": "turbo build",
		"prepare:husky": "npx husky install .husky",
		"prepare": "husky",
		"lint": "turbo lint",
		"type-check": "turbo type-check",
		"clean": "turbo clean",
		"format": "prettier --write \"**/*.{ts,tsx,jsx,json,css,md}\""
	},
	"keywords": [],
	"devDependencies": {
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"husky": "^9.1.7",
		"prettier": "^3.7.4",
		"prettier-eslint-cli": "^8.0.1",
		"prettier-plugin-tailwindcss": "^0.5.14",
		"turbo": "^2.7.5"
	},
	"engines": {
		"node": ">=20",
		"pnpm": ">=9.9.0"
	},
	"packageManager": "pnpm@10.28.2",
	"prettier": {
		"printWidth": 120,
		"singleQuote": true,
		"semi": true,
		"useTabs": true,
		"tabWidth": 4,
		"arrowParens": "always",
		"trailingComma": "none",
		"quoteProps": "as-needed",
		"trimTrailingWhitespace": true,
		"overrides": [
			{
				"files": "*.scss",
				"options": {
					"useTabs": false,
					"tabWidth": 2
				}
			},
			{
				"files": "*.yml",
				"options": {
					"useTabs": false,
					"tabWidth": 2
				}
			}
		]
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"snyk": true
}
