# =============================================================================
# .env.compose — environment for `docker-compose.yml` / `docker-compose.build.yml`
# =============================================================================
# Production-shaped stack: Postgres + Redis + optional self-hosted Trigger.dev.
# Defaults match the service names in `docker-compose.infra.yml`, so the stack
# stands up with zero edits. Replace placeholder secrets before exposing
# anything publicly.
#
# For a minimal SQLite-only demo, use .env.demo.compose with
# `docker-compose.demo.yml` instead.
# =============================================================================

# SHARED CONFIGURATION
WEB_URL=http://localhost:3000

# =============================================================================
# WEB APP CONFIGURATION
# =============================================================================

# AUTH SECRET
AUTH_SECRET=secure-cookie-secret-here

# WEB APP
NEXT_PUBLIC_WEB_URL=${WEB_URL}

# SERVER API URL
API_URL=http://ever-works-api:3100

# ALLOWED REDIRECT HOSTS (comma-separated)
# Useful for authenticating external tools
# hosts listed here will be redirected back with a session token. 
ALLOWED_REDIRECT_URLS=localhost,127.0.0.1


# =============================================================================
# API APP CONFIGURATION
# =============================================================================

# App type
APP_TYPE=api

# API Port
PORT=3100

# Debugging
HTTP_DEBUG=false

# (WEB_URL is defined once at the top of this file, in SHARED CONFIGURATION.)

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# AUTH RUNTIME CONFIGURATION
# =============================================================================

AUTH_URL=http://ever-works-api:3100/api/internal/auth-runtime

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================

# GitHub Auth
GH_CLIENT_ID=
GH_CLIENT_SECRET=
GH_CALLBACK_URL="${WEB_URL}/api/oauth/github/callback"

###############
# Google Auth
###############

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL="${WEB_URL}/api/oauth/google/callback"

# Facebook Auth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL="${WEB_URL}/api/oauth/facebook/callback"

# LinkedIn Auth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL="${WEB_URL}/api/oauth/linkedin/callback"

# Jitsu Analytics
JITSU_HOST=
JITSU_WRITE_KEY=

# =============================================================================
# Trigger.dev configuration
# =============================================================================
# Default: off. Cloud is the recommended path — sign up at https://trigger.dev,
# set TRIGGER_SECRET_KEY, and leave TRIGGER_API_URL at the default.
#
# Self-hosted (docker-compose.trigger.yml, profile `trigger`): override
# TRIGGER_API_URL=http://ever-works-trigger-webapp:3000 and set
# TRIGGER_SECRET_KEY to a token minted in the local webapp.

TRIGGER_ENABLED=false
TRIGGER_SECRET_KEY=
TRIGGER_API_URL="https://api.trigger.dev"
TRIGGER_INTERNAL_SECRET=
# micro | small-1x | small-2x | medium-1x | medium-2x | large-1x | large-2x
TRIGGER_MACHINE=
# To be defined on Trigger.dev Worker or Trigger.dev Cloud.
TRIGGER_INTERNAL_API_URL=http://ever-works-api:3100/internal/trigger

# ─── Self-hosted Trigger.dev knobs (only used with docker-compose.trigger.yml) ─
# Pinned image tag — bump to a specific v4 release for reproducibility.
TRIGGER_IMAGE_TAG=v4
# Public URL where the webapp answers (host-side port; the container exposes 3000).
TRIGGER_LOGIN_ORIGIN=http://localhost:3040
TRIGGER_APP_ORIGIN=http://localhost:3040
TRIGGER_WEBAPP_PUBLISH_PORT=3040
TRIGGER_DB_USER=trigger
TRIGGER_DB_PASS=trigger_password
TRIGGER_DB_PUBLISH_PORT=5433
TRIGGER_REDIS_PUBLISH_PORT=6389
# Secrets — generate each with `openssl rand -hex 32` (produces 64 hex
# characters = 32 bytes, the format Trigger.dev expects for the encryption
# key). Left empty here so the webapp refuses to start until you fill them
# in, rather than silently launching with predictable placeholder values.
TRIGGER_SESSION_SECRET=
TRIGGER_MAGIC_LINK_SECRET=
TRIGGER_ENCRYPTION_KEY=
TRIGGER_MANAGED_WORKER_SECRET=
# Comma-separated emails permitted to sign in to the self-hosted instance.
TRIGGER_WHITELISTED_EMAILS=


# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database type: sqlite | postgres | mysql
# Default for the main compose stack is `postgres` (see docker-compose.infra.yml).
# For the lightweight demo (docker-compose.demo.yml + .env.demo.compose) it's `sqlite`.
DATABASE_TYPE=postgres

# =============================================================================
# POSTGRESQL CONFIGURATION (when DATABASE_TYPE=postgres)
# =============================================================================
# These defaults match the `ever-works-db` service in docker-compose.infra.yml.
# Override here, on the host shell, or in a `.env` file to use a managed Postgres.

DATABASE_HOST=ever-works-db
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=ever_works_password
DATABASE_NAME=ever_works
# DATABASE_URL=

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Used by the distributed throttler (apps/api) and BullMQ-backed queues in
# @ever-works/agent. Matches the `ever-works-redis` service in infra compose.

REDIS_URL=redis://ever-works-redis:6379
THROTTLER_REDIS_URL=redis://ever-works-redis:6379

# =============================================================================
# SQLITE CONFIGURATION (only when DATABASE_TYPE=sqlite — demo path)
# =============================================================================
# Left for reference; not used unless you flip DATABASE_TYPE back to `sqlite`.
# DATABASE_PATH=./data/database.db
# DATABASE_IN_MEMORY=true

# =============================================================================
# MIGRATIONS
# =============================================================================
# Run TypeORM migrations on container startup. Safe for the bundled Postgres;
# turn off if you run migrations out-of-band (CI/CD, separate job, etc.).
RUN_MIGRATIONS=true

# =============================================================================
# MYSQL/MARIADB CONFIGURATION (only when DATABASE_TYPE=mysql)
# =============================================================================

# DATABASE_HOST=localhost
# DATABASE_PORT=3306
# DATABASE_USERNAME=root
# DATABASE_PASSWORD=your_password
# DATABASE_NAME=ever_works
# DATABASE_URL=

# =============================================================================
# COMMON DATABASE OPTIONS
# =============================================================================

# Enable SQL query logging (true/false)
DATABASE_LOGGING=false

# Enable SSL/TLS for database connections (true/false)
DATABASE_SSL_MODE=false
DATABASE_CA_CERT=

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# MAILER PROVIDER: smtp|none|resend
MAILER_PROVIDER=none

# Email from
EMAIL_FROM='Ever Works <ever@ever.works>'

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_password
SMTP_SECURE=false
SMTP_IGNORE_TLS=false

# RESEND
RESEND_APIKEY=
RESEND_EMAIL_FROM=

# =============================================================================
# TWENTY CONFIGURATION
# =============================================================================

TWENTY_CRM_BASE_URL=https://api.twenty.com
TWENTY_CRM_API_KEY=
TWENTY_CRM_WORKSPACE_ID=

TWENTY_CRM_MAX_RETRIES=3
TWENTY_CRM_RETRY_DELAY_MS=1000
TWENTY_CRM_BACKOFF_MULTIPLIER=2
TWENTY_CRM_TIMEOUT_MS=30000
TWENTY_CRM_ENABLE_LOGGING=true

# =============================================================================
# SCHEDULED DIRECTORY UPDATES
# =============================================================================

SCHEDULED_UPDATES_ENABLED=true
SCHEDULED_UPDATES_DISPATCH_INTERVAL_MINUTES=5
SCHEDULED_UPDATES_MAX_BATCH=25
SCHEDULED_UPDATES_MAX_FAILURE_BEFORE_PAUSE=3
PAY_PER_USE_PRICE_USD=5

# =============================================================================
# SUBSCRIPTIONS & BILLING
# =============================================================================

SUBSCRIPTIONS_ENABLED=false
BILLING_DEFAULT_CURRENCY=usd
SUBSCRIPTIONS_DEFAULT_PLAN=free
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# WEBSITE TEMPLATE AUTO-UPDATE
# =============================================================================

# Enable automatic website template updates (true/false)
WEBSITE_TEMPLATE_AUTO_UPDATE_ENABLED=true

# Beta branch name for beta template updates
WEBSITE_TEMPLATE_BETA_BRANCH=stage

# Stale generation timeout in hours (default: 2 hours)
DIRECTORY_STALE_TIMEOUT_HOURS=2

# ============================== PLUGINS ========================================

# GitHub Plugin (separate from GitHub Auth above)
PLUGIN_GITHUB_CLIENT_ID=
PLUGIN_GITHUB_CLIENT_SECRET=
# Redirect URL or callback: [WEB_DOMAIN]/api/oauth/github/callback/plugins

# Tavily Plugin
PLUGIN_TAVILY_API_KEY=

# ScreenshotOne Plugin
PLUGIN_SCREENSHOTONE_ACCESS_KEY=
PLUGIN_SCREENSHOTONE_SECRET_KEY=

# OpenRouter Plugin (default AI provider)
PLUGIN_OPENROUTER_API_KEY=
PLUGIN_OPENROUTER_DEFAULT_MODEL='openai/gpt-5-nano'
PLUGIN_OPENROUTER_SIMPLE_MODEL='openai/gpt-5-nano'
PLUGIN_OPENROUTER_MEDIUM_MODEL='moonshotai/kimi-k2.5'
PLUGIN_OPENROUTER_COMPLEX_MODEL='moonshotai/kimi-k2.5'

# ─── Onboarding Wizard v2 — Ever Works default providers ────────────────────
# Each platform-default is env-gated until its external resource is provisioned.

# "Ever Works Git" storage — push customer repos to a platform-owned GitHub org
STORAGE_EVER_WORKS_GIT_ENABLED=false
EVER_WORKS_CUSTOMERS_GITHUB_ORG=ever-works-cloud
EVER_WORKS_CUSTOMERS_GITHUB_PAT=
EVER_WORKS_CUSTOMERS_GITHUB_VISIBILITY=private

# "Ever Works" deploy — platform-owned Kubernetes tenant cluster
DEPLOY_EVER_WORKS_ENABLED=false
EVER_WORKS_DEPLOY_KUBECONFIG=
EVER_WORKS_DEPLOY_KUBECONFIG_PATH=
EVER_WORKS_DEPLOY_NAMESPACE=ever-works-tenants
EVER_WORKS_DEPLOY_INGRESS_HOST_TEMPLATE={slug}.ever.works
EVER_WORKS_DEPLOY_INGRESS_CLASS=nginx
EVER_WORKS_DEPLOY_TLS_ISSUER=letsencrypt-prod
EVER_WORKS_DEPLOY_REGISTRY=
EVER_WORKS_DEPLOY_MAX_WORKS_PER_USER=3

# ─── User Research Agent (EW-584) ───────────────────────────────────────────
# Tool-calling AI agent that researches new users at signup and generates
# personalized Work proposals.

# Kill switch for the signup listener (default on).
USER_RESEARCH_ENABLED=true

# Daily @Cron rerun for users with stale profiles (default off — opt in per env).
USER_RESEARCH_SCHEDULED_RERUN_ENABLED=false
USER_RESEARCH_SCHEDULED_RERUN_BATCH=20
USER_RESEARCH_SCHEDULED_RERUN_STALE_DAYS=30

# Max providers tried per call (per capability) before giving up. Caps fallback
# so a flapping vendor can't burn through every configured key. Default 2.
USER_RESEARCH_PROVIDER_FALLBACK_MAX=2
