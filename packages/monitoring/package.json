{
    "name": "@packages/monitoring",
    "version": "0.1.0",
    "description": "Monitoring package for Sentry and PostHog integration",
    "private": true,
    "license": "UNLICENSED",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./sentry": {
            "types": "./dist/sentry/index.d.ts",
            "default": "./dist/sentry/index.js"
        },
        "./posthog": {
            "types": "./dist/posthog/index.d.ts",
            "default": "./dist/posthog/index.js"
        },
        "./interceptors": {
            "types": "./dist/interceptors/index.d.ts",
            "default": "./dist/interceptors/index.js"
        },
        "./services": {
            "types": "./dist/services/index.d.ts",
            "default": "./dist/services/index.js"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "default": "./dist/types/index.js"
        }
    },
    "scripts": {
        "dev": "concurrently \"npm:build:dev\" \"npm:build:types:dev\"",
        "build": "nest build -b swc && tsc --emitDeclarationOnly --declarationMap true",
        "build:dev": "nest build -b swc --watch",
        "build:types": "tsc --emitDeclarationOnly --declarationMap true",
        "build:types:dev": "tsc --emitDeclarationOnly --declarationMap true --watch",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "peerDependencies": {
        "@nestjs/common": "^11.1",
        "@nestjs/core": "^11.1",
        "@nestjs/platform-express": "^11.1",
        "reflect-metadata": "^0.2",
        "rxjs": "^7.8"
    },
    "dependencies": {
        "@sentry/nestjs": "^10.32.1",
        "@sentry/profiling-node": "^10.32.1",
        "posthog-node": "^5.18.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.14",
        "@nestjs/schematics": "^11.0.9",
        "@nestjs/testing": "^11.1.10",
        "@swc/cli": "^0.6.0",
        "@swc/core": "^1.15.7",
        "@types/express": "^5.0.6",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.19.3",
        "@types/supertest": "^6.0.3",
        "concurrently": "^9.2.1",
        "jest": "^29.7.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.1.4",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3"
    }
}
