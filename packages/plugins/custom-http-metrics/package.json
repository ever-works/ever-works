{
	"name": "@ever-works/custom-http-metrics-plugin",
	"version": "1.0.0",
	"description": "Custom HTTP Metrics Plugin - read-only metrics provider that reads numeric values from user-configured GET-only JSON endpoints",
	"author": {
		"name": "Ever Co. LTD",
		"email": "ever@ever.co",
		"url": "https://ever.co"
	},
	"license": "AGPL-3.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsc --noEmit && tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"peerDependencies": {
		"@ever-works/plugin": "workspace:*"
	},
	"devDependencies": {
		"@ever-works/plugin": "workspace:*",
		"@types/node": "^22.0.0",
		"tsup": "^8.4.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"everworks": {
		"plugin": {
			"id": "custom-http-metrics",
			"name": "Custom HTTP Metrics",
			"version": "1.0.0",
			"category": "metrics",
			"capabilities": [
				"metrics-provider"
			],
			"description": "Read numeric metric values from your own HTTP endpoints (GET-only, JSON). Each configured endpoint becomes one metric that Goals can evaluate targets against.",
			"author": {
				"name": "Ever Works Team"
			},
			"license": "AGPL-3.0"
		}
	}
}
