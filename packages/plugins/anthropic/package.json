{
	"name": "@ever-works/anthropic-plugin",
	"version": "1.0.0",
	"description": "Anthropic AI provider plugin for Ever Works platform",
	"private": false,
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@ever-works/plugin": "workspace:*",
		"@langchain/openai": "^0.6.17",
		"@langchain/core": "^0.3.80"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.1"
	},
	"everworks": {
		"plugin": {
			"id": "anthropic",
			"name": "Anthropic",
			"version": "1.0.0",
			"category": "ai-provider",
			"capabilities": [
				"ai-provider"
			],
			"description": "Anthropic AI provider plugin for Ever Works platform",
			"author": {
				"name": "Ever Works Team"
			},
			"license": "MIT",
			"builtIn": true,
			"autoInstall": false,
			"autoEnable": false,
			"icon": {
				"type": "svg",
				"value": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M13.827 3.52h3.603L24 20.48h-3.603l-6.57-16.96zm-7.258 0h3.767L16.906 20.48h-3.674l-1.343-3.461H5.017l-1.344 3.46H.001L6.57 3.522zm2.327 4.806L6.47 14.353h4.853L8.896 8.326z\"/></svg>",
				"backgroundColor": "#191919"
			}
		}
	}
}
