{
	"name": "@ever-works/local-content-extractor-plugin",
	"version": "1.0.0",
	"description": "Local Content Extractor - System plugin for extracting web page content using axios + Readability",
	"private": true,
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"peerDependencies": {
		"@ever-works/plugin": "workspace:*"
	},
	"dependencies": {
		"@mozilla/readability": "^0.6.0",
		"axios": "^1.13.4",
		"linkedom": "^0.18.12",
		"turndown": "^7.2.2"
	},
	"devDependencies": {
		"@ever-works/plugin": "workspace:*",
		"@types/turndown": "^5.0.5",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.0.0"
	},
	"everworks": {
		"plugin": {
			"id": "local-content-extractor",
			"name": "Local Content Extractor",
			"version": "1.0.0",
			"category": "content-extractor",
			"capabilities": [
				"content-extractor"
			],
			"description": "System plugin for extracting web page content using axios + Readability. Provides fallback content extraction without requiring external API keys.",
			"author": {
				"name": "Ever Works Team"
			},
			"license": "MIT",
			"autoEnable": true,
			"systemPlugin": true,
			"builtIn": true,
			"visibility": "public",
			"defaultForCapabilities": [
				"content-extractor"
			]
		}
	}
}
