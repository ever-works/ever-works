{
	"name": "@ever-works/notion-extractor-plugin",
	"version": "1.0.0",
	"description": "Notion Page Extractor - Extract content from Notion pages using the Notion API or Splitbee",
	"author": {
		"name": "Ever Co. LTD",
		"email": "ever@ever.co",
		"url": "https://ever.co"
	},
	"license": "AGPL-3.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsc --noEmit && tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@notionhq/client": "^2.3.0",
		"axios": "^1.15.2"
	},
	"peerDependencies": {
		"@ever-works/plugin": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@ever-works/plugin": "workspace:*",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.0.0"
	},
	"everworks": {
		"plugin": {
			"id": "notion-extractor",
			"name": "Notion Page Extractor",
			"version": "1.0.0",
			"category": "content-extractor",
			"capabilities": [
				"content-extractor"
			],
			"description": "Extract content from Notion pages. Supports both public pages (via Splitbee) and private pages (via Notion API).",
			"author": {
				"name": "Ever Works Team"
			},
			"license": "AGPL-3.0",
			"systemPlugin": false,
			"builtIn": false,
			"isDefault": false
		}
	}
}
