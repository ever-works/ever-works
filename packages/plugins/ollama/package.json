{
	"name": "@ever-works/ollama-plugin",
	"version": "1.0.0",
	"description": "Ollama AI provider plugin for Ever Works platform",
	"private": false,
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@ever-works/plugin": "workspace:*",
		"@langchain/openai": "^0.6.17",
		"@langchain/core": "^0.3.80"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.1"
	},
	"everworks": {
		"plugin": {
			"id": "ollama",
			"name": "Ollama",
			"version": "1.0.0",
			"category": "ai-provider",
			"capabilities": [
				"ai-provider"
			],
			"description": "Ollama AI provider plugin for Ever Works platform",
			"author": {
				"name": "Ever Works Team"
			},
			"license": "MIT",
			"builtIn": true,
			"autoInstall": false,
			"autoEnable": false,
