{
	"name": "@ever-works/slack-channel-plugin",
	"version": "1.0.0",
	"description": "Slack notification-channel plugin for Ever Works platform",
	"author": {
		"name": "Ever Co. LTD",
		"email": "ever@ever.co",
		"url": "https://ever.co"
	},
	"license": "AGPL-3.0",
	"private": false,
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc --noEmit && tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@ever-works/plugin": "workspace:*",
		"@slack/webhook": "^7.0.5"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.1"
	},
	"everworks": {
		"plugin": {
			"id": "slack-channel",
			"name": "Slack",
			"version": "1.0.0",
			"category": "notification-channel",
			"capabilities": [
				"notification-channel",
				"notification-channel-slack"
			],
			"description": "Post notifications to a Slack channel via an incoming webhook (Block Kit supported).",
			"settings": {
				"type": "object",
				"properties": {
					"defaultUsername": {
						"type": "string",
						"title": "Default sender username"
					},
					"defaultIconEmoji": {
						"type": "string",
						"title": "Default sender icon emoji (e.g. :robot_face:)"
					}
				}
			}
		}
	}
}
