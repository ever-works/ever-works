{
	"name": "@ever-works/claude-code-plugin",
	"version": "1.0.0",
	"description": "Claude Code Generator Plugin - Full pipeline plugin that delegates generation to Claude Code",
	"private": true,
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"peerDependencies": {
		"@ever-works/plugin": "workspace:*"
	},
	"devDependencies": {
		"@ever-works/plugin": "workspace:*",
		"@types/node": "^22.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.1"
	},
	"everworks": {
		"plugin": {
			"id": "claude-code",
			"name": "Claude Code Generator",
			"version": "1.0.0",
			"category": "pipeline",
			"capabilities": [
				"pipeline",
				"form-schema-provider"
			],
			"description": "Full pipeline plugin that delegates the entire generation to Claude Code",
			"author": {
				"name": "Ever Works Team"
			},
			"license": "MIT",
			"builtIn": true,
			"autoEnable": false,
			"visibility": "public"
		}
	}
}
