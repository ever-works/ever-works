{
	"name": "@ever-works/brave-plugin",
	"version": "1.0.0",
	"description": "Brave Plugin - Privacy-focused web search using Brave Search API",
	"private": true,
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"peerDependencies": {
		"@ever-works/plugin": "workspace:*"
	},
	"dependencies": {},
	"devDependencies": {
		"@ever-works/plugin": "workspace:*",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.0.0"
	},
	"everworks": {
		"plugin": {
			"id": "brave",
			"name": "Brave Search",
			"version": "1.0.0",
			"category": "search",
			"capabilities": [
				"search"
			],
			"description": "Privacy-focused web search using the Brave Search API. Independent search index with no tracking.",
			"author": {
				"name": "Ever Works Team"
			},
			"license": "MIT",
			"autoEnable": false,
			"systemPlugin": false,
			"builtIn": true,
			"envVars": [
				{
					"name": "PLUGIN_BRAVE_API_KEY",
					"required": false,
					"secret": true,
					"description": "Brave Search API key (optional - can be set via admin/user settings)"
				}
			],
			"icon": {
				"type": "svg",
				"value": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M20.44 7.11l-.56-1.63 1.05-1.68a.56.56 0 00-.08-.69L18.72 1a.56.56 0 00-.55-.14L16 1.52l-1.35-.8A13.85 13.85 0 0012 0a13.85 13.85 0 00-2.65.72L8 1.52l-2.17-.66A.56.56 0 005.28 1L3.15 3.11a.56.56 0 00-.08.69L4.12 5.48l-.56 1.63a14.9 14.9 0 00-.64 2.87L2 12.71a.56.56 0 00.14.55L4 15.32l.37 2.2a14 14 0 001.15 3.32l1.76 2.28a.56.56 0 00.6.2l2.14-.68 2 .65a.56.56 0 00.34 0l2-.65 2.14.68a.56.56 0 00.6-.2l1.76-2.28a14 14 0 001.15-3.32l.37-2.2L22 13.26a.56.56 0 00.14-.55l-.92-2.73a14.9 14.9 0 00-.78-2.87z\" fill=\"url(#brave-grad)\"/><defs><linearGradient id=\"brave-grad\" x1=\"12\" y1=\"0\" x2=\"12\" y2=\"24\" gradientUnits=\"userSpaceOnUse\"><stop stop-color=\"#FF5500\"/><stop offset=\"0.41\" stop-color=\"#FF5500\"/><stop offset=\"1\" stop-color=\"#FF2000\"/></linearGradient></defs></svg>"
			}
		}
	}
}
