{
	"name": "@ever-works/postmark-plugin",
	"version": "1.0.0",
	"description": "Postmark email provider plugin (outbound + inbound) for Ever Works platform",
	"author": {
		"name": "Ever Co. LTD",
		"email": "ever@ever.co",
		"url": "https://ever.co"
	},
	"license": "AGPL-3.0",
	"private": false,
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc --noEmit && tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@ever-works/plugin": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.1"
	},
	"everworks": {
		"plugin": {
			"id": "postmark",
			"name": "Postmark",
			"version": "1.0.0",
			"category": "email-provider",
			"capabilities": [
				"email-outbound",
				"email-inbound"
			],
			"description": "Send + receive email through Postmark Server API + Inbound Streams.",
			"settings": {
				"type": "object",
				"properties": {
					"apiKey": {
						"type": "string",
						"title": "Server API token",
						"x-secret": true,
						"x-envVar": "POSTMARK_API_KEY"
					},
					"defaultSenderDomain": {
						"type": "string",
						"title": "Default sender domain"
					},
					"inboundWebhookSecret": {
						"type": "string",
						"title": "Inbound webhook secret (Basic Auth)",
						"x-secret": true,
						"x-envVar": "POSTMARK_INBOUND_SECRET"
					},
					"inboundStreamId": {
						"type": "string",
						"title": "Inbound stream id (optional)"
					}
				},
				"required": [
					"apiKey"
				]
			}
		}
	}
}
