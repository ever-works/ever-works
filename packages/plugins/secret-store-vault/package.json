{
	"name": "@ever-works/secret-store-vault-plugin",
	"version": "1.0.0",
	"description": "HashiCorp Vault SecretStoreResolver plugin for Ever Works — resolves vault:<path> pointers via the Vault KV v1/v2 REST API. Opt-in via SECRET_STORE_RESOLVER DI binding override.",
	"author": {
		"name": "Ever Co. LTD",
		"email": "ever@ever.co",
		"url": "https://ever.co"
	},
	"license": "AGPL-3.0",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsc --noEmit && tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"peerDependencies": {
		"@ever-works/plugin": "workspace:*"
	},
	"devDependencies": {
		"@ever-works/plugin": "workspace:*",
		"@types/node": "^22.0.0",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3",
		"vitest": "^4.1.0"
	},
	"everworks": {
		"plugin": {
			"id": "secret-store-vault",
			"name": "HashiCorp Vault Secret Store",
			"version": "1.0.0",
			"category": "secret-store-resolver",
			"capabilities": [
				"secret-store-resolve"
			],
			"description": "Resolves vault:<path> pointers via the HashiCorp Vault KV v1/v2 REST API for the EW-742 tenant overlay. Operators using Vault override the SECRET_STORE_RESOLVER DI binding to this plugin.",
			"author": {
				"name": "Ever Works Team"
			},
			"license": "AGPL-3.0",
			"autoEnable": false,
			"systemPlugin": false,
			"distribution": "core",
			"builtIn": true,
			"visibility": "operator",
			"envVars": [
				{
					"name": "VAULT_ADDR",
					"required": true,
					"secret": false,
					"description": "Vault server URL (e.g. https://vault.internal:8200)."
				},
				{
					"name": "VAULT_TOKEN",
					"required": true,
					"secret": true,
					"description": "Vault token with read permission on the requested paths."
				}
			]
		}
	}
}
