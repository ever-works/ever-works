{
	"name": "@ever-works/resend-plugin",
	"version": "1.0.0",
	"description": "Resend email provider plugin (outbound only) for Ever Works platform",
	"author": {
		"name": "Ever Co. LTD",
		"email": "ever@ever.co",
		"url": "https://ever.co"
	},
	"license": "AGPL-3.0",
	"private": false,
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc --noEmit && tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@ever-works/plugin": "workspace:*",
		"resend": "^4.5.1"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"everworks": {
		"plugin": {
			"id": "resend",
			"name": "Resend",
			"version": "1.0.0",
			"category": "email-provider",
			"capabilities": [
				"email-outbound"
			],
			"description": "Send transactional + agent-driven email through Resend. Inbound is deferred until Resend GA (currently private beta).",
			"settings": {
				"type": "object",
				"properties": {
					"apiKey": {
						"type": "string",
						"title": "Resend API key",
						"x-secret": true,
						"x-envVar": "RESEND_API_KEY"
					},
					"defaultSenderDomain": {
						"type": "string",
						"title": "Default sender domain"
					}
				},
				"required": [
					"apiKey"
				]
			}
		}
	}
}
