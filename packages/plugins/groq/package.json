{
	"name": "@ever-works/groq-plugin",
	"version": "1.0.0",
	"description": "Groq AI provider plugin for Ever Works platform",
	"private": false,
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@ever-works/plugin": "workspace:*",
		"@langchain/openai": "^0.6.17",
		"@langchain/core": "^0.3.80"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.1"
	},
	"ever-works-plugin": {
		"id": "groq",
		"category": "ai-provider",
		"capabilities": [
			"ai-provider"
		],
		"icon": {
			"type": "svg",
			"value": "<svg viewBox=\"0 0 33 33\" fill=\"currentColor\"><path d=\"M16.5 0C7.387 0 0 7.387 0 16.5S7.387 33 16.5 33 33 25.613 33 16.5 25.613 0 16.5 0zm7.5 22.5-4.5-4.5L15 22.5 7.5 15l4.5-4.5L16.5 15 21 10.5l4.5 4.5-1.5 1.5z\"/></svg>",
			"backgroundColor": "#F55036"
		},
		"builtIn": true,
		"autoInstall": false,
		"autoEnable": false
	}
}
