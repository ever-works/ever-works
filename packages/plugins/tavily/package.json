{
	"name": "@ever-works/tavily-plugin",
	"version": "1.0.0",
	"description": "Tavily Plugin - Web search and content extraction using Tavily API",
	"private": true,
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsc --noEmit && tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@tavily/core": "^0.5.0"
	},
	"peerDependencies": {
		"@ever-works/plugin": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@ever-works/plugin": "workspace:*",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.0.0"
	},
	"everworks": {
		"plugin": {
			"id": "tavily",
			"name": "Tavily",
			"version": "1.0.0",
			"category": "search",
			"capabilities": [
				"search",
				"content-extractor"
			],
			"description": "Web search and content extraction using Tavily API. Supports both search queries and direct URL content extraction.",
			"author": {
				"name": "Ever Works Team"
			},
			"license": "MIT",
			"autoEnable": true,
			"defaultForCapabilities": [
				"search"
			],
			"systemPlugin": true,
			"builtIn": true,
			"envVars": [
				{
					"name": "PLUGIN_TAVILY_API_KEY",
					"required": false,
					"secret": true,
					"description": "Tavily API key (optional - can be set via admin/user settings)"
				}
			]
		}
	}
}
