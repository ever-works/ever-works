{
	"name": "@ever-works/default-pipeline-plugin",
	"version": "1.0.0",
	"description": "Default Pipeline Plugin - System plugin providing the standard generation pipeline",
	"private": true,
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"peerDependencies": {
		"@ever-works/plugin": "workspace:*"
	},
	"dependencies": {
		"@langchain/textsplitters": "^0.1.0",
		"string-similarity-js": "^2.1.4",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@ever-works/plugin": "workspace:*",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.0.0"
	},
	"everworks": {
		"plugin": {
			"id": "default-pipeline",
			"name": "Default Pipeline",
			"version": "1.0.0",
			"category": "pipeline",
			"capabilities": [
				"pipeline-step",
				"form-schema-provider"
			],
			"description": "System plugin providing the standard 15-step generation pipeline",
			"author": {
				"name": "Ever Works Team"
			},
			"license": "MIT",
			"systemPlugin": true,
			"builtIn": true,
			"visibility": "hidden"
		}
	}
}
