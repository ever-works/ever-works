{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "build/**", ".next/**"]
		},
		"start": {
			"dependsOn": ["^build"],
			"cache": false
		},
		"start:dev": {
			"dependsOn": ["^build"],
			"persistent": true,
			"cache": false
		},
		"dev": {
			"outputs": [],
			"persistent": true,
			"cache": false
		},
		"dev:trigger": {
			"outputs": [],
			"persistent": true,
			"cache": false
		},
		"lint": {
			"outputs": []
		},
		"test": {
			"outputs": []
		},
		"test:e2e": {
			"outputs": [],
			"cache": false
		},
		"type-check": {
			"outputs": []
		},
		"clean": {
			"outputs": []
		}
	}
}
